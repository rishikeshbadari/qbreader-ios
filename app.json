{
  "expo": {
    "name": "QBReader",
    "slug": "quizbowl",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "qbreader",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/images/icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.rbadari.quizbowl"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.rbadari.quizbowl"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-logo-v2.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#0F172A",
          "dark": {
            "image": "./assets/images/splash-logo-v2.png",
            "backgroundColor": "#0F172A"
          },
          "ios": {
            "image": "./assets/images/splash-logo-v2.png",
            "imageWidth": 240,
            "resizeMode": "contain",
            "backgroundColor": "#0F172A",
            "dark": {
              "image": "./assets/images/splash-logo-v2.png",
              "backgroundColor": "#0F172A"
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "https://uwdahgoyvqdbliqvcfij.supabase.co",
