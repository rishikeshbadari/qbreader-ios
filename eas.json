{
  "cli": {
    "version": ">= 16.18.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_USE_PAIRED_LOOPBACK": "0"
      },
      "ios": {
        "distribution": "store"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
